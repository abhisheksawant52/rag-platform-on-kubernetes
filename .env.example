# Example environment configuration for the rag_platform package.
# Copy to .env and adjust. All variables use the RAGPLATFORM_ prefix.

# --- Application ---
RAGPLATFORM_APP_NAME=rag-platform
RAGPLATFORM_ENVIRONMENT=development
RAGPLATFORM_LOG_LEVEL=INFO
RAGPLATFORM_HOST=0.0.0.0
RAGPLATFORM_PORT=8000

# --- Vector store ---
RAGPLATFORM_VECTOR_STORE_URL=http://qdrant:6333
RAGPLATFORM_COLLECTION_NAME=rag_documents

# --- Models ---
RAGPLATFORM_EMBEDDING_MODEL=text-embedding-3-small
RAGPLATFORM_EMBEDDING_DIM=384
RAGPLATFORM_LLM_MODEL=gpt-4o-mini

# --- Retrieval / chunking ---
RAGPLATFORM_TOP_K=5
RAGPLATFORM_CHUNK_SIZE=512
RAGPLATFORM_CHUNK_OVERLAP=64
RAGPLATFORM_MAX_TOKENS=1024
RAGPLATFORM_TEMPERATURE=0.2

# --- Security (comma-free JSON list) ---
RAGPLATFORM_ALLOWED_ORIGINS=["*"]
